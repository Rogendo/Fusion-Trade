# ── App ──────────────────────────────────────────────────────────────────────
APP_NAME=FusionTrade AI
APP_VERSION=1.0.0
DEBUG=true
API_HOST=0.0.0.0
API_PORT=1999
CORS_ORIGINS=["http://localhost:3000","http://localhost:5173","http://127.0.0.1:1999"]

# ── Auth ──────────────────────────────────────────────────────────────────────
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./data/fusion_trade.db

# ── Redis / Celery ────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=465
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_ADDRESS=your-email@gmail.com
SMTP_USE_SSL=true
FRONTEND_URL=http://localhost:5173

# ── Hugging Face ──────────────────────────────────────────────────────────────
HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
HF_LSTM_REPO=rogendo/forex-lstm-models
HF_TST_REPO=rogendo/forex-patchtst-models

# ── LLM ──────────────────────────────────────────────────────────────────────
LLM_PROVIDER=claude
CLAUDE_API_KEY=sk-ant-xxxxxxxxxxxxxxxxxxxxx
CLAUDE_MODEL=claude-sonnet-4-20250514

# ── MT5 (hookable, disabled by default) ──────────────────────────────────────
MT5_ENABLED=false
MT5_AUTO_EXECUTE=false
